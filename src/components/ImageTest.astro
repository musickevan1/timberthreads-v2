---
import { Image } from 'astro:assets';
import heroImage from '../assets/images/hero-front-view.jpeg';
---

<div class="grid md:grid-cols-2 gap-8">
  <div>
    <h3 class="font-serif text-lg text-stone-700 mb-3">Local Image Pipeline (Astro)</h3>
    <Image
      src={heroImage}
      alt="Astro Image pipeline test - retreat exterior"
      widths={[400, 800, 1200]}
      sizes="(max-width: 768px) 100vw, 50vw"
      class="rounded-lg shadow-md w-full max-w-lg"
    />
    <p class="text-sm text-stone-500 mt-2">Processed at build time to WebP/AVIF with responsive srcset</p>
  </div>
  <div>
    <h3 class="font-serif text-lg text-stone-700 mb-3">CDN Image Pipeline (Cloudinary)</h3>
    <img
      src="https://res.cloudinary.com/demo/image/upload/w_400,f_auto,q_auto/sample.jpg"
      alt="Cloudinary CDN test image"
      width="400"
      height="267"
      loading="lazy"
      class="rounded-lg shadow-md w-full max-w-lg"
    />
    <p class="text-sm text-stone-500 mt-2">Served from Cloudinary CDN with automatic format optimization</p>
  </div>
</div>
