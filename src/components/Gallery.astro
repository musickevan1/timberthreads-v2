---
import GalleryCategory from './GalleryCategory.astro';
import PromoVideo from './PromoVideo.astro';
import { propertyImages, bedroomImages, workspaceImages, quiltImages } from '../data/gallery';
---

<section id="gallery" class="py-16 md:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section heading -->
    <div class="text-center mb-12">
      <h2 class="font-serif text-3xl md:text-4xl text-stone-900 mb-4">Gallery</h2>
      <div class="w-24 h-1 bg-brand mx-auto mb-8"></div>
    </div>

    <!-- Promo video (YouTube embed) -->
    <div class="mb-16">
      <PromoVideo videoId="MTgmkjcghWE" />
    </div>

    <!-- Category grids -->
    <div class="space-y-12">
      <GalleryCategory title="The Property" images={propertyImages} />
      <GalleryCategory title="Bedrooms" images={bedroomImages} />
      <GalleryCategory title="Workspaces" images={workspaceImages} />
      <GalleryCategory title="Quilts" images={quiltImages} />
    </div>

  </div>
</section>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';

  // Initialize one lightbox per category gallery to keep navigation within categories
  document.querySelectorAll<HTMLElement>('[data-pswp-gallery]').forEach((gallery) => {
    const lightbox = new PhotoSwipeLightbox({
      gallery,
      children: 'a',
      pswpModule: () => import('photoswipe'),

      // Zoom behavior for mobile (pinch-to-zoom, double-tap zoom)
      initialZoomLevel: 'fit',
      secondaryZoomLevel: 1.5,
      maxZoomLevel: 3,
    });

    // Caption support via custom UI element
    // Reads plain text from data-pswp-caption attribute on slide anchor elements
    lightbox.on('uiRegister', function () {
      lightbox.pswp!.ui!.registerElement({
        name: 'custom-caption',
        order: 9,
        isButton: false,
        appendTo: 'root',
        onInit: (el: HTMLElement) => {
          lightbox.pswp!.on('change', () => {
            const currSlideElement = lightbox.pswp!.currSlide!.data.element as HTMLElement | undefined;
            const caption = currSlideElement?.getAttribute('data-pswp-caption') || '';
            el.textContent = caption;
            el.style.display = caption ? '' : 'none';
          });
        },
      });
    });

    lightbox.init();
  });
</script>
