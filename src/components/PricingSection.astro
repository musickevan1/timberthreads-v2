---
import PricingCalculator from './PricingCalculator.tsx';
---

<section id="pricing-calculator" class="py-16 md:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-12">
      <h2 class="font-serif text-3xl md:text-4xl text-stone-800 mb-4">Estimate Your Stay</h2>
      <div class="w-24 h-1 bg-brand mx-auto mb-8"></div>
      <p class="text-lg text-stone-600 max-w-2xl mx-auto">
        Use the calculator below to get an estimate for your group's stay. Adjust the sliders and toggle meals to see your breakdown.
      </p>
    </div>

    <!-- Static rate summary — both pricing tiers shown alongside the calculator (per user decision) -->
    <div class="grid sm:grid-cols-2 gap-6 max-w-3xl mx-auto mb-12">
      <div class="bg-stone-50 rounded-lg p-6 text-center">
        <p class="font-serif text-lg text-stone-800 mb-2">Groups of 10 or fewer</p>
        <p class="text-3xl font-bold text-brand mb-1">$60<span class="text-base font-normal text-stone-500">/night</span></p>
        <p class="text-stone-600 text-sm">per person, standard</p>
        <p class="text-stone-500 text-sm mt-2">or $75/night per person with meals</p>
      </div>
      <div class="bg-stone-50 rounded-lg p-6 text-center">
        <p class="font-serif text-lg text-stone-800 mb-2">Groups of 10&ndash;12</p>
        <p class="text-3xl font-bold text-brand mb-1">$600<span class="text-base font-normal text-stone-500">/night</span></p>
        <p class="text-stone-600 text-sm">flat rate for the entire center</p>
      </div>
    </div>
    <p class="text-center text-stone-500 text-sm mb-10">Minimum 4 persons &middot; Minimum 2-night stay</p>

    <PricingCalculator client:load />

  </div>
</section>
