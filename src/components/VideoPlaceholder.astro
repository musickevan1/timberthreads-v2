---
interface Props {
  posterSrc: string;
}

const { posterSrc } = Astro.props;
---

<div class="relative w-full aspect-video max-h-[60vh] overflow-hidden bg-stone-900 rounded-lg">
  <!-- Poster image -->
  <img
    src={posterSrc}
    alt="Timber & Threads Retreat — promo video coming soon"
    loading="lazy"
    class="w-full h-full object-cover opacity-70"
  />

  <!-- Centered overlay -->
  <div class="absolute inset-0 flex flex-col items-center justify-center gap-4">
    <!-- Play icon circle -->
    <div class="w-20 h-20 rounded-full bg-white/20 border-2 border-white/60 backdrop-blur-sm flex items-center justify-center">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="white"
        class="w-9 h-9 ml-1"
        aria-hidden="true"
      >
        <path d="M8 5v14l11-7z"/>
      </svg>
    </div>

    <!-- Coming Soon badge -->
    <span class="px-4 py-1.5 bg-brand/80 rounded-full text-sm font-medium tracking-wide text-white">
      Promo Video Coming Soon
    </span>
  </div>
</div>
