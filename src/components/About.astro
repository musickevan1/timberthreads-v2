---
import { Image } from 'astro:assets';
import quiltDisplay1 from '../assets/images/quilt-display-1-cropped.jpg';
import quiltTreePattern from '../assets/images/quilt-tree-pattern.png';
import v2QuiltingWorkspace from '../assets/images/v2-quilting-workspace.jpg';
import v2WorkspaceBrightWindows from '../assets/images/v2-workspace-bright-windows.jpg';
---

<section id="about" class="py-16 md:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-12">
      <h2 class="font-serif text-3xl md:text-4xl text-stone-800 mb-4">Welcome to Timber &amp; Threads</h2>
      <div class="w-24 h-1 bg-brand mx-auto mb-8"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Left column: text -->
      <div class="space-y-6">
        <p class="text-lg text-stone-700 leading-relaxed">
          Nestled on a peaceful island surrounded by a small lake in Clinton, Missouri, Timber &amp; Threads Retreat offers a unique quilting and crafting getaway. Our retreat center is designed to inspire creativity while providing a serene escape from the busy world.
        </p>
        <p class="text-lg text-stone-700 leading-relaxed">
          Our all-on-one-level facility features comfortable accommodations, dedicated workspaces, and a tranquil natural setting. Whether you're here for a quilting retreat, crafting weekend, or family gathering, we provide an environment where creativity and relaxation flow naturally.
        </p>
      </div>

      <!-- Right column: 2x2 image grid — links to gallery -->
      <div class="grid grid-cols-2 gap-4">
        <!-- Top-left: Quilt display (star pattern) -->
        <a href="#gallery" class="group relative aspect-square rounded-lg overflow-hidden block">
          <Image
            src={quiltDisplay1}
            alt="Colorful handmade quilt with traditional star pattern"
            widths={[400, 800]}
            sizes="(max-width: 768px) 50vw, 25vw"
            class="object-cover w-full h-full"
          />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors duration-300 flex items-center justify-center">
            <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-white text-base font-medium">View Gallery</span>
          </div>
        </a>
        <!-- Top-right: Workshop -->
        <a href="#gallery" class="group relative aspect-square rounded-lg overflow-hidden block">
          <Image
            src={v2QuiltingWorkspace}
            alt="Quilting workspace with large cutting mat table and quilts on the wall"
            widths={[400, 800]}
            sizes="(max-width: 768px) 50vw, 25vw"
            class="object-cover w-full h-full object-[50%_40%]"
          />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors duration-300 flex items-center justify-center">
            <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-white text-base font-medium">View Gallery</span>
          </div>
        </a>
        <!-- Bottom-left: Crafting area -->
        <a href="#gallery" class="group relative aspect-square rounded-lg overflow-hidden block">
          <Image
            src={v2WorkspaceBrightWindows}
            alt="Spacious crafting area with tables, chairs, and bright windows"
            widths={[400, 800]}
            sizes="(max-width: 768px) 50vw, 25vw"
            class="object-cover w-full h-full object-[50%_45%]"
          />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors duration-300 flex items-center justify-center">
            <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-white text-base font-medium">View Gallery</span>
          </div>
        </a>
        <!-- Bottom-right: Quilt display (nature/flowers) -->
        <a href="#gallery" class="group relative aspect-square rounded-lg overflow-hidden block">
          <Image
            src={quiltTreePattern}
            alt="Colorful quilted tree pattern with geometric leaf design"
            widths={[400, 800]}
            sizes="(max-width: 768px) 50vw, 25vw"
            class="object-cover w-full h-full object-[50%_30%]"
          />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors duration-300 flex items-center justify-center">
            <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-white text-base font-medium">View Gallery</span>
          </div>
        </a>
      </div>
    </div>

  </div>
</section>
