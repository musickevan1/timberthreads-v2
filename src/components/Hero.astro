---
import { Image } from 'astro:assets';
import heroImage from '../assets/images/hero-front-view.jpeg';
import logoImage from '../assets/images/logo.png';
---

<section id="home" class="relative h-screen overflow-hidden">
  <!-- Background layer: image + dark overlay -->
  <div class="absolute inset-0 z-0">
    <Image
      src={heroImage}
      alt="Timber & Threads Retreat exterior front view — a charming retreat nestled among trees in the Missouri Ozarks"
      widths={[768, 1280, 1920]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      class="w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-black/30"></div>
  </div>

  <!-- Foreground layer: logo, heading, tagline, CTAs -->
  <div class="relative z-10 flex flex-col items-center justify-center h-full text-center text-white px-4">
    <Image
      src={logoImage}
      alt="Timber & Threads Retreat logo"
      width={130}
      loading="eager"
      class="mb-6 drop-shadow-lg"
    />
    <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-medium mb-4 drop-shadow-md">
      Timber &amp; Threads Retreat
    </h1>
    <p class="text-xl md:text-2xl mb-8 drop-shadow-sm max-w-2xl">
      Relax, create, and connect in nature's embrace
    </p>
    <div class="flex flex-col sm:flex-row gap-4">
      <a
        href="#about"
        class="bg-brand hover:bg-brand-dark text-white px-6 py-3 rounded-lg transition-colors font-medium"
      >
        Learn More
      </a>
      <a
        href="#contact"
        class="border-2 border-white text-white hover:bg-white hover:text-stone-900 px-6 py-3 rounded-lg transition-colors font-medium"
      >
        Contact Us to Book
      </a>
    </div>
  </div>
</section>
