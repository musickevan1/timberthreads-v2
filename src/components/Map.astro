---
import { Image } from 'astro:assets';
import entranceDriveway from '../assets/images/entrance-driveway-summer.jpg';
import entranceGate from '../assets/images/v2-property-entrance.jpg';
---

<section id="location" class="py-16 md:py-24 bg-stone-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-12">
      <h2 class="font-serif text-3xl md:text-4xl text-stone-800 mb-4">Find Us</h2>
      <div class="w-24 h-1 bg-brand mx-auto mb-8"></div>
      <p class="text-lg text-stone-600 max-w-2xl mx-auto">
        Discover the tranquil location of<br class="sm:hidden" /> Timber &amp; Threads Retreat
      </p>
    </div>

    <!-- Two-column: Map + Directions -->
    <div class="grid md:grid-cols-2 gap-8 mb-12">

      <!-- Left column: Google Maps embed (lazy-loaded) -->
      <div class="bg-white rounded-lg shadow-sm overflow-hidden">
        <div class="relative w-full" style="padding-top: 75%;">
          <iframe
            id="maps-iframe"
            data-src="https://www.google.com/maps/embed?pb=!1m34!1m12!1m3!1d24000!2d-93.8027!3d38.3999!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!4m19!3e0!4m5!1s0x87c6a650f50b1783%3A0xd58a1ff5b05b5bfb!2sMallard's%20Roadhouse!3m2!1d38.3896446!2d-93.7928543!4m5!1s0x87c6a63afb6be575%3A0x4209167edbe1bf27!2sNW%20300%20Rd%20%26%20NW%20221%20Rd!3m2!1d38.4111493!2d-93.7965142!4m5!1s0x87c6a610531eb97d%3A0xaebc85a5c037c39b!2s306%20NW%20300%20Rd!3m2!1d38.4101236!2d-93.8125944!5e0!3m2!1sen!2sus"
            class="absolute top-0 left-0 w-full h-full border-0"
            frameborder="0"
            scrolling="no"
            title="Driving directions to Timber & Threads Retreat"
            aria-label="Google Maps showing driving route to retreat"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
        <p class="text-center mt-4 mb-2 text-stone-600">306 NW 300 Rd, Clinton, MO 64735</p>
        <p class="text-center mb-4">
          <a
            href="https://www.google.com/maps/dir/?api=1&destination=306+NW+300+Rd%2CClinton%2CMO+64735&travelmode=driving"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-brand hover:text-teal-700 font-medium transition-colors"
          >
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M4.25 5.5a.75.75 0 00-.75.75v8.5c0 .414.336.75.75.75h8.5a.75.75 0 00.75-.75v-4a.75.75 0 011.5 0v4A2.25 2.25 0 0112.75 17h-8.5A2.25 2.25 0 012 14.75v-8.5A2.25 2.25 0 014.25 4h5a.75.75 0 010 1.5h-5zm7.25-.75a.75.75 0 01.75-.75h3.25a.75.75 0 01.75.75v3.25a.75.75 0 01-1.5 0v-1.44l-4.72 4.72a.75.75 0 01-1.06-1.06l4.72-4.72h-1.44a.75.75 0 01-.75-.75z" clip-rule="evenodd" />
            </svg>
            Open in Google Maps
          </a>
        </p>
      </div>

      <!-- Right column: Driving Directions -->
      <div class="bg-white rounded-lg shadow-sm p-6">
        <h3 class="font-serif text-xl text-stone-800 mb-4">Driving Directions</h3>
        <ol class="space-y-3 text-stone-600">
          <li class="flex gap-3">
            <span class="flex-shrink-0 w-7 h-7 bg-brand text-white rounded-full flex items-center justify-center text-sm font-medium">1</span>
            <span>From Highway 7, turn North onto NW 221 Road <em class="text-stone-500">(near Golden Valley Fireworks and Breaktime Convenience Store)</em></span>
          </li>
          <li class="flex gap-3">
            <span class="flex-shrink-0 w-7 h-7 bg-brand text-white rounded-full flex items-center justify-center text-sm font-medium">2</span>
            <span>Follow the Blacktop Road to the "T" intersection</span>
          </li>
          <li class="flex gap-3">
            <span class="flex-shrink-0 w-7 h-7 bg-brand text-white rounded-full flex items-center justify-center text-sm font-medium">3</span>
            <span>Turn left at the intersection</span>
          </li>
          <li class="flex gap-3">
            <span class="flex-shrink-0 w-7 h-7 bg-brand text-white rounded-full flex items-center justify-center text-sm font-medium">4</span>
            <span>On the first curve, look for a large fence and gate <em class="text-stone-500">(You can't miss the gate entrance)</em></span>
          </li>
          <li class="flex gap-3">
            <span class="flex-shrink-0 w-7 h-7 bg-brand text-white rounded-full flex items-center justify-center text-sm font-medium">5</span>
            <span>Go through the gate</span>
          </li>
          <li class="flex gap-3">
            <span class="flex-shrink-0 w-7 h-7 bg-brand text-white rounded-full flex items-center justify-center text-sm font-medium">6</span>
            <span>Follow the road to the right <em class="text-stone-500">(Continue until you see the Timber &amp; Threads Retreat center)</em></span>
          </li>
        </ol>

        <!-- GPS tip -->
        <div class="mt-4 p-3 bg-amber-50 rounded-lg border border-amber-200">
          <p class="text-base text-amber-800">
            <svg class="inline w-4 h-4 mr-1 align-text-bottom" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
            </svg>
            GPS coordinates can sometimes be unreliable in rural areas. Follow these directions carefully or call ahead if you're unsure.
          </p>
        </div>
      </div>

    </div>

    <!-- Entrance photos -->
    <div class="mt-12 grid md:grid-cols-2 gap-6 max-w-5xl mx-auto">
      <div class="rounded-lg overflow-hidden shadow-sm">
        <div class="aspect-[3/2] overflow-hidden">
          <Image
            src={entranceDriveway}
            alt="Scenic view of the entrance and driveway leading to Timber & Threads Retreat"
            widths={[400, 800]}
            sizes="(max-width: 768px) 100vw, 50vw"
            class="w-full h-full object-cover"
          />
        </div>
        <div class="bg-white p-4">
          <h4 class="font-serif text-lg text-stone-800 mb-1">Approach to the Retreat</h4>
          <p class="text-stone-600 text-base">The scenic driveway leading to Timber &amp; Threads Retreat</p>
        </div>
      </div>
      <div class="rounded-lg overflow-hidden shadow-sm">
        <div class="aspect-[3/2] overflow-hidden">
          <Image
            src={entranceGate}
            alt="Retreat entrance gate with a colorful quilt barn block sign and address marker along a tree-lined gravel drive"
            widths={[400, 800]}
            sizes="(max-width: 768px) 100vw, 50vw"
            class="w-full h-full object-cover"
          />
        </div>
        <div class="bg-white p-4">
          <h4 class="font-serif text-lg text-stone-800 mb-1">The Retreat Entrance</h4>
          <p class="text-stone-600 text-base">A quilt barn block marks the gate — you've arrived</p>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  const iframe = document.getElementById('maps-iframe') as HTMLIFrameElement | null;
  if (iframe) {
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          const src = iframe.dataset.src;
          if (src) iframe.src = src;
          observer.disconnect();
        }
      },
      { rootMargin: '200px 0px' }
    );
    observer.observe(iframe);
  }
</script>
