---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Workshops from '../components/Workshops.astro';
import Accommodations from '../components/Accommodations.astro';
import Calendar from '../components/Calendar.astro';
import PricingSection from '../components/PricingSection.astro';
import Contact from '../components/Contact.astro';
import Map from '../components/Map.astro';
import Gallery from '../components/Gallery.astro';
---

<BaseLayout
  title="Timber & Threads Retreat | Quilting & Crafting Getaway in Clinton, MO"
  description="A private quilting and crafting retreat on a serene island in Clinton, Missouri. Perfect for groups of 4–12. Peaceful lake setting, dedicated workspaces, comfortable accommodations."
  ogImage="/og-image.jpg"
>
  <!-- Hero: #home -->
  <Hero />

  <!-- About: #about -->
  <About />

  <!-- Retreats: #retreats -->
  <Workshops />

  <!-- Accommodations: #accommodations -->
  <Accommodations />

  <!-- Calendar: #calendar -->
  <Calendar />

  <!-- Pricing Calculator: #pricing-calculator -->
  <PricingSection />

  <!-- Gallery: #gallery -->
  <Gallery />

  <!-- Contact: #contact -->
  <Contact />

  <!-- Location: #location -->
  <Map />
</BaseLayout>
