---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Workshops from '../components/Workshops.astro';
import Accommodations from '../components/Accommodations.astro';
import Calendar from '../components/Calendar.astro';
import Contact from '../components/Contact.astro';
import Map from '../components/Map.astro';
import Gallery from '../components/Gallery.astro';
---

<BaseLayout
  title="Timber & Threads Retreat"
  description="A quilting and crafting retreat on a private island in the Missouri Ozarks. Relax, create, and connect in nature's embrace."
>
  <!-- Hero: #home -->
  <Hero />

  <!-- About: #about -->
  <About />

  <!-- Retreats: #retreats -->
  <Workshops />

  <!-- Accommodations: #accommodations -->
  <Accommodations />

  <!-- Calendar: #calendar -->
  <Calendar />

  <!-- Gallery: #gallery -->
  <Gallery />

  <!-- Contact: #contact -->
  <Contact />

  <!-- Location: #location -->
  <Map />
</BaseLayout>
