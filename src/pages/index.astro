---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Workshops from '../components/Workshops.astro';
import ImageTest from '../components/ImageTest.astro';
import Accommodations from '../components/Accommodations.astro';
import Calendar from '../components/Calendar.astro';
import Connect from '../components/Connect.astro';
---

<BaseLayout
  title="Timber & Threads Retreat"
  description="A quilting and crafting retreat on a private island in the Missouri Ozarks. Relax, create, and connect in nature's embrace."
>
  <!-- Hero: #home -->
  <Hero />

  <!-- About: #about -->
  <About />

  <!-- Retreats: #retreats -->
  <Workshops />

  <!-- Accommodations: #accommodations -->
  <Accommodations />

  <!-- Calendar: #calendar -->
  <Calendar />

  <!-- Gallery: #gallery -->
  <section id="gallery" class="py-16 md:py-24 bg-white min-h-[50vh] flex items-center">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
      <div class="mb-8 text-center">
        <h2 class="font-serif text-3xl md:text-4xl text-stone-900 mb-2">Gallery</h2>
        <p class="text-stone-500 text-base">Image Pipeline Test (Phase 1)</p>
      </div>
      <ImageTest />
    </div>
  </section>

  <!-- Contact: #contact -->
  <Connect />

  <!-- Location: #location -->
  <section id="location" class="py-16 md:py-24 bg-teal-50/10 min-h-[50vh] flex items-center">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
      <div class="text-center">
        <h2 class="font-serif text-3xl md:text-4xl text-stone-900 mb-4">Location</h2>
        <p class="text-stone-500 text-lg max-w-2xl mx-auto">Content coming in Phase 2</p>
      </div>
    </div>
  </section>
</BaseLayout>
